# Gateway listen port (public ingress)
PORT=8080

# Upstream monolith base URL that all non-management traffic is proxied to.
# Local dev: the API runs on 3000.
MONOLITH_UPSTREAM_URL=http://localhost:3000

# End-to-end proxy timeout (ms) for incoming + upstream sockets.
GATEWAY_PROXY_TIMEOUT_MS=30000

# development | test | production
NODE_ENV=development
