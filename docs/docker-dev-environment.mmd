%%{init: {"theme": "default", "themeVariables": {"fontSize": "40px", "fontFamily": "arial"}, "flowchart": {"subGraphTitleMargin": {"top": 60, "bottom": 10}, "nodeSpacing": 80, "rankSpacing": 100}}}%%
graph TB
    DEV["Developer Machine\nmacOS / Windows / Linux"]

    subgraph HOST["Host: docker compose -f docker-compose.dev.yml up --build --watch"]
        direction TB

        subgraph BUILD["Image Build (shared backend + frontend dev images)"]
            direction LR
            BASE["FROM node:24-alpine\n+ libc6-compat\n+ pnpm@11.1.2"]
            COPY_MANIFESTS["COPY workspace manifests\npackage.json / pnpm-lock.yaml\npnpm-workspace.yaml / app package.json files"]
            INSTALL["RUN pnpm install --frozen-lockfile\n(dependencies baked into images)"]
            BASE --> COPY_MANIFESTS --> INSTALL
        end

        subgraph NETWORK["Docker Internal Network"]
            direction TB

            subgraph INFRA["Infrastructure Services"]
                PG["postgres\nimage: pgvector/pgvector\nport 5432\nhealthcheck: pg_isready"]
                RD["redis\nimage: redis:7-alpine\nport 6379\nhealthcheck: redis-cli ping"]
                NRD["notification-redis\nimage: redis:7-alpine\nport 6380"]
                MQ["rabbitmq\nimage: rabbitmq:3.13-management-alpine\nports 5672 / 15672"]
            end

            subgraph APPS["App Services"]
                GATEWAY_C["gateway\nCMD: pnpm run dev\nport 8080"]
                SERVICES_C["services\nidentity, media, notification, catalog,\npromotion, payment, review, ordering, reporting"]
                WEB_C["web\nCMD: pnpm run dev\nport 5173"]
                ADMIN_C["admin\nCMD: pnpm run dev\nport 5174"]
            end

            SERVICES_C -- "DATABASE_URL -> postgres:5432" --> PG
            SERVICES_C -- "REDIS_HOST -> redis:6379" --> RD
            SERVICES_C -- "RABBITMQ_URL -> rabbitmq:5672" --> MQ
            WEB_C -- "browser uses localhost:8080" --> GATEWAY_C
            ADMIN_C -- "browser uses localhost:8080" --> GATEWAY_C
            GATEWAY_C --> SERVICES_C
        end

        subgraph VOLUMES["Named Volumes"]
            V1["Postgres data"]
            V2["Redis data"]
            V3["RabbitMQ data"]
        end
    end

    subgraph WATCH["Compose Watch"]
        SRC["Repo source code\nsync src changes\nrebuild on package or Dockerfile changes"]
    end

    subgraph PORTS["Published Ports (host -> container)"]
        P1["localhost:8080 -> gateway:8080"]
        P2["localhost:5173 -> web:5173"]
        P3["localhost:5174 -> admin:5174"]
        P4["localhost:5432 -> postgres:5432"]
        P5["localhost:6379 -> redis:6379"]
        P6["localhost:15672 -> rabbitmq:15672"]
    end

    DEV -- "docker compose up --build --watch" --> BUILD
    BUILD -- "backend image" --> GATEWAY_C
    BUILD -- "backend image" --> SERVICES_C
    BUILD -- "frontend image" --> WEB_C
    BUILD -- "frontend image" --> ADMIN_C

    SRC -- "develop.watch sync/rebuild" --> GATEWAY_C
    SRC -- "develop.watch sync/rebuild" --> SERVICES_C
    SRC -- "develop.watch sync/rebuild" --> WEB_C
    SRC -- "develop.watch sync/rebuild" --> ADMIN_C

    V1 --> PG
    V2 --> RD
    V2 --> NRD
    V3 --> MQ

    GATEWAY_C --> P1
    WEB_C --> P2
    ADMIN_C --> P3
    PG --> P4
    RD --> P5
    MQ --> P6

    DEV -- "opens browser" --> P1
    DEV -- "opens browser" --> P2
    DEV -- "opens browser" --> P3

    style BUILD   fill:#fef9c3,stroke:#ca8a04
    style INFRA   fill:#f0fdf4,stroke:#16a34a
    style APPS    fill:#dbeafe,stroke:#2563eb
    style VOLUMES fill:#f5f3ff,stroke:#7c3aed
    style WATCH   fill:#fff7ed,stroke:#ea580c
    style PORTS   fill:#fdf2f8,stroke:#9d174d
    style HOST    fill:#f8fafc,stroke:#475569