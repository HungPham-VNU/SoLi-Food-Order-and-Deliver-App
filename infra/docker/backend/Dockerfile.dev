# syntax=docker/dockerfile:1.7
FROM node:24-alpine

RUN apk add --no-cache libc6-compat
RUN npm install -g pnpm@11.1.2

ENV CI=true

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY packages/contracts/package.json packages/contracts/package.json
COPY apps/gateway/package.json apps/gateway/package.json
COPY apps/services/catalog/package.json apps/services/catalog/package.json
COPY apps/services/identity/package.json apps/services/identity/package.json
COPY apps/services/media/package.json apps/services/media/package.json
COPY apps/services/notification/package.json apps/services/notification/package.json
COPY apps/services/ordering/package.json apps/services/ordering/package.json
COPY apps/services/payment/package.json apps/services/payment/package.json
COPY apps/services/promotion/package.json apps/services/promotion/package.json
COPY apps/services/reporting/package.json apps/services/reporting/package.json
COPY apps/services/review/package.json apps/services/review/package.json

RUN --mount=type=cache,id=uitfoodms-backend-pnpm-store,target=/pnpm/store \
    pnpm config set store-dir /pnpm/store && \
    pnpm --filter gateway... \
      --filter media... \
      --filter identity... \
      --filter notification... \
      --filter catalog... \
      --filter promotion... \
      --filter payment... \
      --filter review... \
      --filter ordering... \
      --filter reporting... \
      --filter @uitfood/contracts \
      install --frozen-lockfile --config.confirmModulesPurge=false --config.package-import-method=copy

COPY packages/contracts/tsconfig.json packages/contracts/tsconfig.json
COPY packages/contracts/src packages/contracts/src

COPY apps/gateway/nest-cli.json apps/gateway/tsconfig.json apps/gateway/
COPY apps/gateway/src apps/gateway/src

COPY apps/services/catalog/nest-cli.json apps/services/catalog/tsconfig.json apps/services/catalog/drizzle.config.ts apps/services/catalog/
COPY apps/services/catalog/src apps/services/catalog/src

COPY apps/services/identity/nest-cli.json apps/services/identity/tsconfig.json apps/services/identity/drizzle.config.ts apps/services/identity/
COPY apps/services/identity/src apps/services/identity/src

COPY apps/services/media/nest-cli.json apps/services/media/tsconfig.json apps/services/media/drizzle.config.ts apps/services/media/
COPY apps/services/media/src apps/services/media/src

COPY apps/services/notification/nest-cli.json apps/services/notification/tsconfig.json apps/services/notification/drizzle.config.ts apps/services/notification/
COPY apps/services/notification/src apps/services/notification/src

COPY apps/services/ordering/nest-cli.json apps/services/ordering/tsconfig.json apps/services/ordering/drizzle.config.ts apps/services/ordering/
COPY apps/services/ordering/src apps/services/ordering/src

COPY apps/services/payment/nest-cli.json apps/services/payment/tsconfig.json apps/services/payment/drizzle.config.ts apps/services/payment/
COPY apps/services/payment/src apps/services/payment/src

COPY apps/services/promotion/nest-cli.json apps/services/promotion/tsconfig.json apps/services/promotion/drizzle.config.ts apps/services/promotion/
COPY apps/services/promotion/src apps/services/promotion/src

COPY apps/services/reporting/nest-cli.json apps/services/reporting/tsconfig.json apps/services/reporting/drizzle.config.ts apps/services/reporting/
COPY apps/services/reporting/src apps/services/reporting/src

COPY apps/services/review/nest-cli.json apps/services/review/tsconfig.json apps/services/review/drizzle.config.ts apps/services/review/
COPY apps/services/review/src apps/services/review/src

RUN pnpm --filter @uitfood/contracts build
