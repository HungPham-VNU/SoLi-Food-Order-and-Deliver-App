    "EXPO_PUBLIC_APP_ENV",
    "EXPO_PUBLIC_APP_VERSION",
    "EXPO_PUBLIC_COMMIT_SHA"
  ],
  "tasks": {
    "transit": {
      "dependsOn": ["^transit"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**",
        ".expo/**",
        "web-build/**"
      ]
    },
    "test": {
      "dependsOn": ["transit", "^build"]
    },
    "lint": {
      "dependsOn": ["transit", "^build"]
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["transit", "^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
